# Application
NODE_ENV=development
PORT=3005

DATABASE_URL=postgresql://alvee@127.0.0.1:5433/school_db?schema=public

# JWT
JWT_ACCESS_SECRET=change-this-32-char-access-secret!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-32-char-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# File Storage (Cloudflare R2 / S3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=school-assets
R2_PUBLIC_URL=https://cdn.example.com

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3001
